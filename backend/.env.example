# Redis / BullMQ
REDIS_URL=redis://127.0.0.1:6379
SIGNAL_SCAN_INTERVAL_MS=30000
SIGNAL_CACHE_TTL_SECONDS=60

# Scoring
CONFLUENCE_THRESHOLD=75

# Market data provider (placeholder)
# TODO: Replace with your confirmed OHLCV provider values.
MARKET_DATA_PROVIDER=<PROVIDER_NAME_PLACEHOLDER>
MARKET_DATA_BASE_URL=<PROVIDER_BASE_URL_PLACEHOLDER>
MARKET_DATA_API_KEY=<PROVIDER_API_KEY_PLACEHOLDER>

# Auth
JWT_SECRET=<JWT_SECRET_PLACEHOLDER>

# Optional MT5 bridge key (if empty, MT5 bridge accepts local unauthenticated polling)
MT5_BRIDGE_API_KEY=

# MT5 placeholders for your .mph alignment
MT5_POLLING_ENDPOINT_PATH=<MT5_POLLING_ENDPOINT_PLACEHOLDER>
MT5_EXECUTION_CALLBACK_PATH=<MT5_EXECUTION_CALLBACK_PLACEHOLDER>
MT5_SIGNAL_PAYLOAD_SHAPE=<MT5_SIGNAL_PAYLOAD_SHAPE_PLACEHOLDER>
MT5_EXECUTION_RESULT_SHAPE=<MT5_EXECUTION_RESULT_SHAPE_PLACEHOLDER>

